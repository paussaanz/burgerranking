---
import Layout from '../components/Layout.astro';
import HeroSection from '../components/HeroSection.astro';
import BurgerGrid from '../components/BurgerGrid';
import { getCollection } from 'astro:content';

const allBurgers = await getCollection('burgers');

// Sort by rating desc for initial display
const burgersData = allBurgers
  .sort((a, b) => b.data.rating_general - a.data.rating_general)
  .map((b) => ({
    slug: b.slug,
    nombre: b.data.nombre,
    barrio: b.data.barrio,
    precio_rango: b.data.precio_rango,
    rating_general: b.data.rating_general,
    tags: b.data.tags,
    fecha_visita: b.data.fecha_visita.toISOString(),
    foto_portada: b.data.foto_portada,
    descripcion: b.data.descripcion,
    hamburguesa_estrella: b.data.hamburguesa_estrella,
  }));
---

<Layout title="Rankings">
  <HeroSection count={burgersData.length} />

  <section class="ranking-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">El ranking</h2>
        <p class="section-subtitle">
          Ordenado por rating general · Última actualización {new Date().toLocaleDateString('es-ES', { month: 'long', year: 'numeric' })}
        </p>
      </div>

      <BurgerGrid burgers={burgersData} client:load />
    </div>
  </section>
</Layout>

<style>
  .ranking-section {
    padding-block: var(--space-3xl);
  }

  .section-header {
    margin-bottom: var(--space-xl);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 5rem);
    color: var(--color-text);
    line-height: 1;
    letter-spacing: 0.03em;
  }

  .section-title::after {
    content: '.';
    color: var(--color-accent);
  }

  .section-subtitle {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
    letter-spacing: 0.04em;
  }
</style>
